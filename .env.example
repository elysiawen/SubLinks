# Server
NEXT_PUBLIC_URL=http://localhost:3000
JWT_SECRET=

# OAuth Token Encryption (optional but recommended)
# Set a strong random string to encrypt OAuth tokens at rest
# If not set, tokens are stored in plaintext (backward compatible)
OAUTH_TOKEN_SECRET=

# Database (choose one)
DATABASE_TYPE=postgres
POSTGRES_URL=postgresql://user:password@localhost:5432/dbname
MYSQL_URL=mysql://user:password@localhost:3306/dbname

# Admin
ADMIN_PASSWORD=admin

# Analytics (optional, only enabled in production)
CLARITY_ID=

UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

GA_MEASUREMENT_ID=G-XXXXXXXXXX
